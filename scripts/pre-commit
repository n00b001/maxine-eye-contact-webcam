#!/usr/bin/env bash
# Pre-commit hook: ruff lint + format + pytest coverage >= 80%.
# Invoked by git because core.hooksPath points at this directory.
# Mirrors .pre-commit-config.yaml so either path (raw hook or pre-commit
# framework) enforces identical checks.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "Running pre-commit checks..."

echo "-> ruff check"
uv run ruff check .

echo "-> ruff format --check"
if ! uv run ruff format --check .; then
    echo ""
    echo "Formatting errors detected. Run:"
    echo "  uv run ruff format ."
    echo "Then stage and re-commit."
    exit 1
fi

echo "-> pytest with coverage >= 80%"
uv run pytest --cov --cov-fail-under=80

echo "Pre-commit checks passed."
