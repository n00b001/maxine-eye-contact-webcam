#!/usr/bin/env bash
# Pre-commit hook: ruff lint + format + pytest.
# Invoked by git because core.hooksPath points at this directory.
# Mirrors .pre-commit-config.yaml so either path (raw hook or pre-commit
# framework) enforces identical checks. Coverage gate is off while the
# unified-pipeline rewrite is in progress — tests exercise logic inside
# the Docker image, not the (currently empty) host Python surface.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "Running pre-commit checks..."

echo "-> ruff check"
uv run ruff check .

echo "-> ruff format --check"
if ! uv run ruff format --check .; then
    echo ""
    echo "Formatting errors detected. Run:"
    echo "  uv run ruff format ."
    echo "Then stage and re-commit."
    exit 1
fi

echo "-> pytest"
uv run pytest

echo "Pre-commit checks passed."
